  //
  // GpuBoostRate              : GPU boost rate per card.
  // (default: 0.041225)
  //
  // MaxCapacity               : maximum number of bitcoins that can accumulate.
  // (default: 3)
  // ─────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────

