{
  // ─────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────
  // MASTER SETTINGS
  // ─────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────

  // Master switch for default trader offers. (defaultTradesConfig.json)
  "EnableDefaultTrades": true,

  // Master switch for automatic handbook → trader routing. (routedTradesConfig.json)
  "EnableRoutedTrades": false,

  // Master switch for manual trader offers. (manualTradesConfig.json)
  "EnableManualTrades": false,

  // Master switch for Fence configuration. (fenceConfig.json)
  "EnableFenceConfig": false,

  // Master switch for trader buyback rules configuration. (buybackConfig.json)
  "EnableBuybackConfig": false,

  // Master switch for trader supply configuration. (supplyConfig.json)
  "EnableSupplyConfig": false,

  // Master switch for hideout configuration. (hideoutConfig.json)
  "EnableHideoutConfig": false,

  // Master switch for crafting recipe overrides. (craftingConfig.json)
  "EnableCraftingConfig": false,

  // Master switch for insurance configuration. (insuranceConfig.json)
  "EnableInsuranceConfig": false,

  // Master switch for handbook prices overrides. (handbookPricesConfig.json)
  "EnableHandbookPricesConfig": false,

  // Master switch for flea market configuration. (fleaMarketConfig.json)
  "EnableFleaMarketConfig": false,

  // ─────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────
  // DEV SETTINGS
  // ─────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────

  // Force all assort prices to 1 rouble, ignoring all price config.
  "EnableDevMode": false,

  // Enable verbose logging.
  "EnableDevLogs": false,
}
