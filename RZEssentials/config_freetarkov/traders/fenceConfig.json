{
  // ─────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────
  // MASTER TOGGLE - Set to true to enable this config.
  // ─────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────

  "EnableFenceConfig": true,

  // ─────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────
  // DEFAULT ITEM POOL
  //
  // SPT's native fence generation system. On each refresh, SPT randomly picks items from a built-in pool and generates offers from them.
  // Discount variants apply to the secondary tab (unlocked at rep level 6).
  // ─────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────

  // Master switch. If false, zeroes all native generation counts and ignores both this entire section AND DefaultItemPoolAdditions.
  "EnableDefaultItemPool": false,

  // Number of regular items (ammo, meds, gear...) per refresh. Default: 120.
  "AssortSize": 120,

  // Number of preconfigured weapons with mods per refresh. Default: min 12, max 19.
  "WeaponPresetMinMax": { "Min": 12, "Max": 19 },

  // Number of preconfigured armor rigs with plates per refresh. Default: min 8, max 15.
  "EquipmentPresetMinMax": { "Min": 8, "Max": 15 },

  // Price multiplier applied to all regular items. Default: 1.3.
  "ItemPriceMult": 1.3,

  // Price multiplier applied to all weapon and equipment presets. Default: 1.3.
  "PresetPriceMult": 1.3,

  // Number of regular items in the discount tab per refresh. Default: 45.
  "DiscountAssortSize": 45,

  // Number of preconfigured weapons in the discount tab per refresh. Default: min 5, max 12.
  "DiscountWeaponPresetMinMax": { "Min": 5, "Max": 12 },

  // Number of preconfigured armors in the discount tab per refresh. Default: min 5, max 12.
  "DiscountEquipmentPresetMinMax": { "Min": 5, "Max": 12 },

  // Price multiplier applied to all regular items in the discount tab. Default: 0.8.
  "DiscountItemPriceMult": 0.8,

  // Price multiplier applied to all weapon and equipment presets in the discount tab. Default: 1.15.
  "DiscountPresetPriceMult": 1.15,

  // ─────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────
  // DEFAULT ITEM POOL ADDITIONS
  //
  // Extends the built-in pool with extra items. Only active if EnableDefaultItemPool is also true.
  // ─────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────

  // Switch for this sub-section only.
  "EnableDefaultItemPoolAdditions": false,

  // DefaultItemPoolAdditions — items to add to the pool. LoyaltyLevel = rep level required (1 = always visible or 2 = above 6 rep)
  "DefaultItemPoolAdditions": [
    { "Tpl": "5c0530ee86f774697952d952", "RoublePrice": 800000, "LoyaltyLevel": 1 }, // LEDX
  ],

  // ─────────────────────────────────────────────────────────────────────────
  // CUSTOM ITEM POOL
  //
  // Completely independent from the default pool. Defines a weighted pool of offers that are injected directly into fence assorts each
  // refresh, on top of whatever the default pool generates.
  //
  // CustomItemPool — the pool to draw from. Each offer supports:
  //   Tpl          — item template ID
  //   Weight       — relative draw chance (higher = more likely to be picked)
  //   StackSize    — quantity per offer slot
  //   CurrencyTpl  — currency TPL (roubles / dollars / euros / GP coin / etc.)
  //   Price        — price in the chosen currency
  //   LoyaltyLevel — fence rep level required (1 = always visible)
  // ─────────────────────────────────────────────────────────────────────────

  // Switch for this sub-section only.
  "EnableCustomItemPool": true,

  // How many offers to draw from the pool per refresh.
  "CustomItemCount": 10,

  // Price multiplier.
  "CustomItemPriceMultiplier": 5.0,

