{
  // MASTER SWITCH - Set to true to enable this config file.
  "EnableItemContext": false,

  // ─────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────
  // AMMO NAME ENRICHMENT
  //
  // Appends [dmg:x/pen:x] color-coded stats to ammo item names.
  // ShowPrefixes : Ahow "dmg:" / "pen:" labels, or just the values.
  // Thresholds : Applied top-down, first match wins. Values below the lowest threshold get no color.
  // ─────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────

  "AmmoNameEnrichment": {

    "Enabled": true,

    "ShowPrefixes": true,

    "DamageThresholds": [
      { "Min": 90, "Color": "#cc4444" },
      { "Min": 70, "Color": "#cccc44" },
      { "Min": 50, "Color": "#8844cc" },
      { "Min": 30, "Color": "#4444cc" }
    ],

    "PenetrationThresholds": [
      { "Min": 60, "Color": "#cc4444" },
      { "Min": 50, "Color": "#cccc44" },
      { "Min": 40, "Color": "#8844cc" },
      { "Min": 30, "Color": "#4444cc" }
    ]

  },

  // ─────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────
  // BASE PRICE DISPLAY
  //
  // Appends a color-coded [x₽] suffix to item names for the listed categories.
  // Thresholds : Applied top-down, first match wins.
  // ─────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────

  "BasePriceDisplay": {

    "Enabled": true,

    "Categories": {
      "566162e44bdc2d3f298b4573": true, // CompoundItem (Containers, Equipment, Mods)
      "5448eb774bdc2d0a728b4567": true, // BarterItem
      "5661632d4bdc2d903d8b456b": true, // StackableItem (Ammo, Money)
      "543be6674bdc2df1348b4569": true, // FoodDrink
      "543be5e94bdc2df1348b4568": true, // Key
      "543be5664bdc2dd4348b4569": true, // Meds
      "5447e0e74bdc2d3c308b4567": true, // SpecItem
      "5447e1d04bdc2dff2f8b4567": true, // Knife
      "567849dd4bdc2d150f8b456e": true, // Map
      "5448ecbe4bdc2d60728b4568": true, // Info
      "543be6564bdc2df4348b4568": true, // ThrowWeap
      "6759673c76e93d8eb20b2080": true, // Flyer
    },

    "PriceThresholds": [
      { "Min": 150000, "Color": "#cc4444" },
      { "Min": 70000, "Color": "#cccc44" },
      { "Min": 50000, "Color": "#8844cc" },
      { "Min": 30000, "Color": "#4444cc" },
      { "Min": 0, "Color": "#ffffff" }
    ]

  },

  // ─────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────
  // DESCRIPTION CLEANUP
  //
  // Removes the vanilla description for items in the listed categories.
  // ─────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────

  "DescriptionCleanup": {
    "Enabled": true,
    "Categories": [
      "5485a8684bdc2da71d8b4567", // Ammo
      "644120aa86ffbe10ee032b6f", // ArmorPlate
    ]
  },

  // ─────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────
