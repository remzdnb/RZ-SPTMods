  // ─────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────
  // LOCALE OVERRIDES
  //
  // Overrides trader names and descriptions.
  // Fields left empty or omitted are ignored, only what you explicitly set is overridden.
  // Currently applies to all languages.
  // ─────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────

  //
  "EnableLocaleOverrides": true,

  //
  "LocaleOverrides": {

    // Prapor
    "54cb50c76803fa8b248b4571": {
      "FullName": "Sidorovich",
      "FirstName": "Sidorovich",
      "Nickname": "Sidorovich",
      "Location": "",
      "Description": "A shrewd black-market trader living in a cramped underground bunker. Surrounded by crates of weapons, supplies, and old equipment, he buys and sells gear to wandering mercenaries and scavengers, always keeping a close eye on profit."
    },

    // Therapist
    "54cb57776803fa99248b456e": {
      "FullName": "Doc",
      "FirstName": "Doc",
      "Nickname": "Doc",
      "Location": "",
      "Description": "A hardened field doctor operating out of a makeshift clinic in a rundown bunker. Known for patching up mercenaries, scavengers, and anyone who can pay, she isn’t too concerned about where the bullets came from. Resourceful and discreet, she keeps questionable supplies, experimental treatments, and a few secrets locked away behind her workbench. Around here, survival matters more than ethics."
    },

    // Fence
    "579dc571d53a0658a154fbec": {
      "FullName": "",
      "FirstName": "",
      "Nickname": "",
      "Location": "",
      "Description": "Known as Fence, she is a mysterious and influential figure with deep ties to the local militia. Operating through favors, quiet deals, and unseen pressure, she controls a vast underground network of supplies and information. Few know her true motives, but crossing her is said to bring consequences that arrive quietly and without warning."
    },

    // Skier
    "58330581ace78e27b8b10cee": {
      "FullName": "Skif",
      "FirstName": "Skif",
      "Nickname": "Skif",
      "Location": "",
      "Description": "A Tarkov veteran who's been through enough to stop counting. Doesn't talk much, doesn't trust easily, and has long since made peace with the fact that this place doesn't reward either. Knows the terrain better than most, keeps his gear in better shape than his relationships, and has a talent for being exactly where trouble isn't.",
    },

    // Peacekeeper
    "5935c25fb3acc3127c3d8cd9": {
      "FullName": "",
      "FirstName": "",
      "Nickname": "",
      "Location": "",
      "Description": "A skilled negotiator and intermediary among rival groups. Calm, perceptive, and disarmingly charming, she works to keep fragile deals from falling apart in a place where trust is rare. Beneath the composed facade, she’s driven by a personal mission: tracking down her missing brother somewhere in the chaos, following rumors and favors wherever they lead."
    },

    // Mechanic
    "5a7c2eca46aef81a7ca2145d": {
      "FullName": "",
      "FirstName": "",
      "Nickname": "",
      "Location": "",
      "Description": "Grew up dismantling whatever he could find just to understand how it worked. He fixed guns before he knew how to shave. Lost his parents young, packed what little he had left, and ended up in Tarkov chasing a contract that didn't pan out. At this point, the work is all he has left."
    },

    // Ragman
    "5ac3b934156ae10c4430e83c": {
      "FullName": "Goldman",
      "FirstName": "Goldman",
      "Nickname": "Goldman",
      "Location": "",
      "Description": "A cunning Tarkov trader, always dressed to impress, with a smile that hides as many secrets as there are bills in his pocket. He knows the value of every coin and every rifle, and he knows exactly how to convince you to hand over your loot… or part with it. Always classy, never rushed, but above all, always paid."
    },

    // Jaeger
    "5c0647fdd443bc2504c2d371": {
      "FullName": "",
      "FirstName": "",
      "Nickname": "",
      "Location": "",
      "Description": "A former hunter who has adapted to life in guerrilla warfare. Patient, quiet, and deeply familiar with the wilderness, he moves through forests and ruins with the instincts of a predator. He teaches others how to survive off the land, track enemies, and strike without being seen."
    },

    // Ref
    "6617beeaa9cfa777ca915b7c": {
      "FullName": "Fixer",
      "FirstName": "Fixer",
      "Nickname": "Fixer",
      "Location": "",
      "Description": "Known simply as the Fixer, he organizes secret death tournaments hidden in abandoned bunkers and forgotten industrial sites. Fighters, gamblers, and mercenaries gather under his watch to test their luck and skill in brutal matches. Quiet and calculating, he stays in the shadows, arranging the fights and collecting his cut while others spill blood in the arena."
    },

    // Sable
    "fa363fc015e07b5f7828c9f7": {
      "FullName": "Sable",
      "FirstName": "Sable",
      "Nickname": "Sable",
      "Location": "",
      "Description": "Officially declared dead after a black site operation went dark in 2018. No body, no report, no explanation, just a name quietly removed from the FSB's active roster and buried under six layers of classified. She resurfaced in Tarkov two years later with a supply line nobody can trace, allegiance to nobody, and enough operational knowledge to make the people who burned her file very uncomfortable."
    }
  },

