  // ─────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────
  // REPAIR OVERRIDES
  //
  // Partial patch of the repair block. Only non-null fields are applied.
  // Field names match SPT's TraderRepair JsonPropertyName attributes:
  //   availability         — enable/disable repair service (true/false)
  //   quality              — repair quality as a double (0.0 to 1.0)
  //   currency             — currency TPL or "RUB" | "USD" | "EUR"
  //   currency_coefficient — coefficient applied to currency price
  //   price_rate           — base price rate for repair
  //   excluded_id_list     — item TPL strings that cannot be repaired (replaces existing list)
  //   excluded_category    — MongoId strings of categories excluded from repair (replaces existing list)
  // ─────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────

  //
  "EnableRepairOverrides": false,

